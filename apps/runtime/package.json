{
  "name": "dota2-coach",
  "version": "1.0.0",
  "description": "Dota 2 AI Coach runtime",
  "private": true,
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:smoke": "node test/smoke-built-runtime.mjs",
    "test:watch": "jest --watchAll",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test && npm run build && npm run test:smoke"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "discord.js": "^14.27.0",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@swc/core": "^1.15.46",
    "@swc/jest": "^0.2.39",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
